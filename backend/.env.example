# ─── Application ─────────────────────────────────────────────
APP_NAME=Academic.kz
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/academic_kz
# Sync URL (used by Alembic)
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/academic_kz

# ─── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Pagination ───────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
